# 边缘机部署 env 模板。复制为 deploy/edge/.env 并填真值(.env 已 gitignored,永不入 git)。
EDGE_HOST=                 # 边缘机公网 IP / 域名
IMAGE_OWNER=gwzlchn        # ghcr 镜像归属(ghcr.io/<owner>/flori*);fork 后改自己的
IMAGE_TAG=latest
MINIO_ACCESS_KEY=flori     # MinIO 账号(须与 NAS 端一致)
MINIO_SECRET_KEY=          # MinIO 密钥(必填,>=8 位)
DEEPSEEK_API_KEY=
KIMI_API_KEY=
# Caddy basic_auth 的 bcrypt 哈希:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext '你的口令'
FLORI_BASIC_HASH=
