{
	# 自签场景:无 SNI(按 IP 访问)时也给出证书
	default_sni {$EDGE_HOST}
	# 不绑 80(对外只 443+22),禁用 HTTP->HTTPS 自动跳转
	auto_https disable_redirects
}

https://{$EDGE_HOST}, https://localhost, https://127.0.0.1 {
	tls internal

	# /api/runner/* 是 worker↔网关的机机接口,自带 Bearer 鉴权(注册 token + 每 worker
	# token),且 worker 只发 Authorization: Bearer——与 Basic 同头冲突,故须放行不挂 Basic。
	@protected not path /api/runner/*

	# 一道门:对人面入口(SPA + /api/* 非 runner)全站 Basic Auth。
	# NAS 端 API_TOKEN 已置空,应用层不再要 Bearer;前端也不发 Authorization,
	# 浏览器对所有请求自动带 Basic 凭证,不会与任何 Bearer 头冲突。
	basic_auth @protected {
		flori {$FLORI_BASIC_HASH}
	}

	# /api/*(含 /api/runner/*)反代到 NAS api(反向 SSH 隧道口)。
	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	# 前端:反代到本机 flori-frontend 容器(Watchtower 跟随 CI 自动更新)。
	handle {
		reverse_proxy 127.0.0.1:8090
	}
}
